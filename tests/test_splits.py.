from pathlib import Path
import numpy as np

from physiofusion.windowing import build_dataset
from physiofusion.splits import subject_grouped_split

import pytest 

ROOT = Path(__file__).resolve().parents[1]   # tests/ is one level below root
BIG = ROOT / "Data" / "big-ideas-lab-glycemic-variability-and-wearable-device-data-1.1.2"
SUBJECTS = [f"{i:03d}" for i in range(1, 17) if i != 15]   # drop 015

'''
why decoration
scope="function" (default) → rebuilt for every test function
scope="class" → rebuilt once per test class
scope="module" → rebuilt once per test file 
scope="session" → rebuilt once for the entire test run, across all files
'''
@pytest.fixture(scope="module") # decoration
def dataset():
    """Build (X, y, groups) once and hand it to every test that asks."""
    X, y, groups = build_dataset(BIG, SUBJECTS)
    return X, y, groups


# Test 1 - no subject is in BOTH train and test.

def test_no_subject_leakage(dataset):
    X, y, groups = dataset
    train_idx, test_idx = subject_grouped_split(groups, n_splits=5, fold=0)

    # which subjects landed in each pile
    train_subjects = set(groups[train_idx])
    test_subjects = set(groups[test_idx])

    # the overlap between the two sets MUST be empty
    overlap = train_subjects & test_subjects
    assert overlap == set(), f"LEAKAGE: subjects in both piles: {overlap}"

# TEST 2 — nobody vanishes: every subject appears somewhere.
def test_no_subject_lost(dataset):
    X, y, groups = dataset
    train_idx, test_idx = subject_grouped_split(groups, n_splits=5, fold=0)

    all_subjects = set(groups)                       # everyone we put in
    used_subjects = set(groups[train_idx]) | set(groups[test_idx])  # everyone dealt

    assert used_subjects == all_subjects, (
        f"LOST subjects: {all_subjects - used_subjects}"
    )

# TEST 3 — the split covers every window exactly once (no dropped/duplicated
# rows). train_idx and test_idx together should account for all N rows.
def test_split_covers_all_windows(dataset):
    X, y, groups = dataset
    train_idx, test_idx = subject_grouped_split(groups, n_splits=5, fold=0)

    # no row should be in both index sets
    assert len(set(train_idx) & set(test_idx)) == 0, "a window is in both piles"

    # together they should cover exactly all N rows
    assert len(train_idx) + len(test_idx) == len(X), "some windows unaccounted for"

# ---------------------------------------------------------------------------
# TEST 4 — the promise must hold for EVERY fold, not just fold 0.
# We loop all 5 folds and re-check no leakage each time.
# ---------------------------------------------------------------------------
def test_no_leakage_across_all_folds(dataset):
    X, y, groups = dataset
    for fold in range(5):
        train_idx, test_idx = subject_grouped_split(groups, n_splits=5, fold=fold)
        overlap = set(groups[train_idx]) & set(groups[test_idx])
        assert overlap == set(), f"LEAKAGE in fold {fold}: {overlap}"